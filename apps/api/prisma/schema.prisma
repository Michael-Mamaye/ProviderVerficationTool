generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QueryType {
  NPI
  NAME
}

enum LookupStatus {
  SUCCESS
  NOT_FOUND
  INVALID_QUERY
  API_ERROR
}

// One row per search a user runs, success or failure. This is the audit
// trail the challenge asks for: query + timestamp + result, always written.
model Lookup {
  id           String       @id @default(uuid())
  query        String
  queryType    QueryType
  status       LookupStatus
  resultCount  Int          @default(0)
  results      Json?
  errorMessage String?
  createdAt    DateTime     @default(now())

  @@index([createdAt])
}
